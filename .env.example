# ── JWT ────────────────────────────────────────────────────────────────────────
# MUST change in production — generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default) — relative paths are auto-anchored to <project-root>/data/.
# Switch to PostgreSQL with:
#   postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///music.db

# ── CORS ───────────────────────────────────────────────────────────────────────
# JSON array of allowed origins. Use ["*"] to allow all (development only).
# Example: CORS_ORIGINS=["http://localhost:5173","https://example.com"]
CORS_ORIGINS=["*"]

# ── Seed / demo account ────────────────────────────────────────────────────────
DEMO_USERNAME=demo
DEMO_EMAIL=demo@example.com
DEMO_PASSWORD=demo123

# ── Server ────────────────────────────────────────────────────────────────────
APP_PORT=8000

# ── Testing（一般无需设置；pytest 在 tests/conftest.py 中设置 BANANA_TESTING）────────
# BANANA_TESTING=true

# ── Upload ────────────────────────────────────────────────────────────────────
# Max worker threads for fingerprint/duration/tag parsing (default: all CPU cores)
UPLOAD_MAX_WORKERS=8
# Chromaprint 指纹后台任务（需系统安装 fpcalc，如 libchromaprint-tools）；不需要时可关闭
# FINGERPRINT_ENABLED=true
# 指纹写入后自动用元数据插件（如 MusicBrainz）补全未知艺人/无专辑等（默认关闭）
# UPLOAD_AUTO_METADATA_AFTER_FINGERPRINT=false

# ── 插件（Ollama / LLM 元数据）──────────────────────────────────────────────────
# 元数据插件配置在仓库根目录 plugins/<id>/config.json，或通过管理后台「插件」页保存。
# llm-metadata 示例（WSL 访问宿主机 Ollama，见 TODO）。model 须与 ollama list 一致，见
# https://ollama.com/library/qwen3.5 （本机常见为 qwen3.5:latest，与 ollama list 一致即可）：
#   { "ollama_base_url": "http://172.19.240.1:11434", "model": "qwen3.5:latest", "timeout_sec": 45 }
